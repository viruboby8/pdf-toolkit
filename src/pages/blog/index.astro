---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { pageTitle } from '@/lib/seo';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base
  title={pageTitle('Blog — PDF Tips & Guides')}
  description="Practical PDF guides: how to compress PDFs for government portals, convert images for Aadhaar, and more — all without uploading your files."
  canonical="/blog"
>
  <h1 class="text-3xl font-bold text-slate-900 mb-2">PDF Tips & Guides</h1>
  <p class="text-slate-500 mb-8">Practical guides for Indian government portals, exam applications, and everyday PDF tasks.</p>

  <ul class="space-y-6">
    {posts.map(post => (
      <li class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm hover:shadow-md transition-shadow">
        <a href={`/blog/${post.slug}`} class="block">
          <h2 class="text-lg font-semibold text-slate-900 hover:text-sky-700 mb-1">{post.data.title}</h2>
          <p class="text-sm text-slate-500 mb-2">
            {post.data.pubDate.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
            {' · '}{post.data.author}
          </p>
          <p class="text-slate-600 text-sm">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</Base>
