---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import { pageTitle, siteUrl } from '@/lib/seo';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, targetSlug, author } = post.data;

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Blog', href: '/blog' },
  { name: title, href: `/blog/${post.slug}` },
];

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  author: { '@type': 'Organization', name: author },
  datePublished: pubDate.toISOString(),
  publisher: { '@type': 'Organization', name: 'PDF Toolkit', logo: { '@type': 'ImageObject', url: `${siteUrl}/icons/icon-192.png` } },
  url: `${siteUrl}/blog/${post.slug}`,
  image: `${siteUrl}/icons/icon-512.png`,
};
---

<Base
  title={pageTitle(title)}
  {description}
  canonical={`/blog/${post.slug}`}
>
  <JsonLd data={articleLd} />
  <Breadcrumbs crumbs={breadcrumbs} />

  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900 mb-2">{title}</h1>
      <p class="text-sm text-slate-500">
        {pubDate.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
        {' · '}{author}
      </p>
    </header>

    <div class="prose prose-slate max-w-none text-slate-600 leading-relaxed">
      <Content />
    </div>

    {targetSlug && (
      <div class="mt-10 p-5 bg-sky-50 border border-sky-200 rounded-xl">
        <p class="font-semibold text-sky-900 mb-1">Use the tool</p>
        <a href={`/${targetSlug}`} class="text-sky-700 hover:underline font-medium">
          Try it free → /{targetSlug}
        </a>
      </div>
    )}
  </article>
</Base>
