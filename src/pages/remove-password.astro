---
import Base from '@/layouts/Base.astro';
import RemovePasswordTool from '@/components/tools/RemovePasswordTool.svelte';
---

<Base
  title="Remove PDF Password — Free, No Upload | PDF Toolkit"
  description="Remove the password from a PDF you own. Enter the current password and download an unlocked copy. No upload, no data sent to any server."
  canonical="/remove-password"
>
  <h1 class="text-3xl font-bold text-slate-900 mb-2">Remove PDF password</h1>
  <p class="text-slate-500 mb-8">
    Unlock a password-protected PDF you already know the password to.
    Enter the current password, and download a copy without it.
    Runs entirely in your browser — the file never leaves your device.
  </p>

  <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
    <RemovePasswordTool client:visible />
  </div>

  <section class="mt-12 space-y-3 text-sm text-slate-600">
    <h2 class="text-lg font-semibold text-slate-800">Frequently asked questions</h2>
    <details class="border border-slate-200 rounded-lg">
      <summary class="px-4 py-3 font-medium text-slate-700 cursor-pointer hover:bg-slate-50">Do I need to know the current password?</summary>
      <p class="px-4 pb-4 pt-2">Yes. This tool removes the password from a PDF you already have access to — it does not crack or bypass passwords. Enter the password you use to open the file.</p>
    </details>
    <details class="border border-slate-200 rounded-lg">
      <summary class="px-4 py-3 font-medium text-slate-700 cursor-pointer hover:bg-slate-50">Is my password sent to a server?</summary>
      <p class="px-4 pb-4 pt-2">No. Everything — the PDF and the password — stays on your device. The decryption happens locally in your browser using WebAssembly. Nothing is transmitted.</p>
    </details>
    <details class="border border-slate-200 rounded-lg">
      <summary class="px-4 py-3 font-medium text-slate-700 cursor-pointer hover:bg-slate-50">What encryption types are supported?</summary>
      <p class="px-4 pb-4 pt-2">The tool supports standard PDF password protection (RC4 40/128-bit and AES 128/256-bit) — the formats used by the vast majority of password-protected PDFs from banks, governments, and document tools.</p>
    </details>
    <details class="border border-slate-200 rounded-lg">
      <summary class="px-4 py-3 font-medium text-slate-700 cursor-pointer hover:bg-slate-50">What if I get an error?</summary>
      <p class="px-4 pb-4 pt-2">Double-check the password. Some PDFs use an "owner password" (restrictions-only) rather than a user password — try leaving the password field empty and clicking Remove.</p>
    </details>
  </section>
</Base>
