---
import Base from '@/layouts/Base.astro';
---

<Base
  title="PDF Toolkit — Free, Unlimited PDF Tools. No Upload."
  description="Merge, split, rotate and compress PDFs entirely in your browser. No file uploads, no daily limits, no watermarks, no signup. 100% private."
>
  <!-- Hero -->
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold text-slate-900 tracking-tight mb-4">
      PDF tools that never leave your browser.
    </h1>
    <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">
      Merge, split, rotate, and more — entirely on your device. Zero uploads.
      No daily limits. No watermarks. Works offline after first load.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-50 text-emerald-700 text-sm font-medium border border-emerald-200">
        ✓ Files stay on your device
      </span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-sky-50 text-sky-700 text-sm font-medium border border-sky-200">
        ✓ No daily limits
      </span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-violet-50 text-violet-700 text-sm font-medium border border-violet-200">
        ✓ No watermarks
      </span>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-orange-50 text-orange-700 text-sm font-medium border border-orange-200">
        ✓ Works offline
      </span>
    </div>
  </section>

  <!-- Tools grid -->
  <section>
    <h2 class="text-xl font-semibold text-slate-800 mb-5">Available tools</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      <a href="/merge-pdf" class="group p-5 bg-white rounded-xl border border-slate-200 hover:border-sky-400 hover:shadow-md transition-all">
        <div class="w-10 h-10 bg-sky-100 text-sky-600 rounded-lg flex items-center justify-center mb-3 group-hover:bg-sky-600 group-hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-800 mb-1">Merge PDF</h3>
        <p class="text-sm text-slate-500">Combine multiple PDFs into one. Drag to reorder pages.</p>
      </a>

      <a href="/split-pdf" class="group p-5 bg-white rounded-xl border border-slate-200 hover:border-sky-400 hover:shadow-md transition-all">
        <div class="w-10 h-10 bg-emerald-100 text-emerald-600 rounded-lg flex items-center justify-center mb-3 group-hover:bg-emerald-600 group-hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-800 mb-1">Split PDF</h3>
        <p class="text-sm text-slate-500">Split by every N pages or extract a specific page range.</p>
      </a>

      <a href="/rotate-pdf" class="group p-5 bg-white rounded-xl border border-slate-200 hover:border-sky-400 hover:shadow-md transition-all">
        <div class="w-10 h-10 bg-violet-100 text-violet-600 rounded-lg flex items-center justify-center mb-3 group-hover:bg-violet-600 group-hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-800 mb-1">Rotate PDF</h3>
        <p class="text-sm text-slate-500">Rotate all pages 90°, 180°, or 270° in one click.</p>
      </a>

      <a href="/reorder-pdf" class="group p-5 bg-white rounded-xl border border-slate-200 hover:border-sky-400 hover:shadow-md transition-all">
        <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-lg flex items-center justify-center mb-3 group-hover:bg-amber-600 group-hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-800 mb-1">Reorder pages</h3>
        <p class="text-sm text-slate-500">Drag page thumbnails to rearrange in any order.</p>
      </a>

      <a href="/delete-pages" class="group p-5 bg-white rounded-xl border border-slate-200 hover:border-sky-400 hover:shadow-md transition-all">
        <div class="w-10 h-10 bg-red-100 text-red-600 rounded-lg flex items-center justify-center mb-3 group-hover:bg-red-600 group-hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-800 mb-1">Delete pages</h3>
        <p class="text-sm text-slate-500">Click thumbnails to select and remove specific pages.</p>
      </a>

      <a href="/extract-pages" class="group p-5 bg-white rounded-xl border border-slate-200 hover:border-sky-400 hover:shadow-md transition-all">
        <div class="w-10 h-10 bg-teal-100 text-teal-600 rounded-lg flex items-center justify-center mb-3 group-hover:bg-teal-600 group-hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-800 mb-1">Extract pages</h3>
        <p class="text-sm text-slate-500">Pick specific pages and save them as a new PDF.</p>
      </a>
    </div>
  </section>

  <!-- How it works -->
  <section class="mt-14">
    <h2 class="text-xl font-semibold text-slate-800 mb-5">How it works</h2>
    <div class="grid sm:grid-cols-3 gap-6 text-sm text-slate-600">
      <div>
        <div class="text-2xl font-bold text-sky-600 mb-2">1</div>
        <p><strong class="text-slate-800">Drop your file.</strong> Select or drag a PDF from your device. It loads instantly — no upload wait.</p>
      </div>
      <div>
        <div class="text-2xl font-bold text-sky-600 mb-2">2</div>
        <p><strong class="text-slate-800">Choose your operation.</strong> Merge, split, or rotate — all processing happens on your CPU using WebAssembly.</p>
      </div>
      <div>
        <div class="text-2xl font-bold text-sky-600 mb-2">3</div>
        <p><strong class="text-slate-800">Download the result.</strong> Your processed PDF downloads directly to your device. Nothing was ever sent anywhere.</p>
      </div>
    </div>
  </section>
</Base>
