---
import JsonLd from './JsonLd.astro';
interface Props { faq: { q: string; a: string }[] }
const { faq } = Astro.props;
const data = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a },
  })),
};
---
<JsonLd {data} />
